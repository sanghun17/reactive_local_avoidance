<launch>
  <!-- topics (remap-able) -->
  <arg name="lidar_topic" default="/livox/lidar"/>
  <arg name="odom_topic"  default="/mavros/local_position/odom"/>

  <!-- load parameters into /Local_Avoidance_SH (absolute namespace used in code) -->
  <rosparam command="load" file="$(find local_avoidance)/config/local_avoidance.yaml"/>

  <node pkg="local_avoidance" type="Local_Avoidance_SH" name="local_avoidance" output="screen">
    <remap from="/livox/lidar"                to="$(arg lidar_topic)"/>
    <remap from="/mavros/local_position/odom" to="$(arg odom_topic)"/>
  </node>
</launch>
